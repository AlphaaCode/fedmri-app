# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fedmri:fedmri@localhost:5432/fedmri"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-in-prod"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-prod"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── AI / Chat ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Storage ───────────────────────────────────────────────────────────────
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"
# Bundled sample MRI volumes for the doctor "Use a sample scan" picker.
SAMPLES_DIR="D:/study/BioInfo M2 (2026)/Memoir/Datasets/breast-mri-molecular-cancer-subtype/samples"

# ── ML Inference ──────────────────────────────────────────────────────────
# real = ml-service runs the FedSCRT ConvNeXt-MIL checkpoint (real predictions +
# real MRI-slice attention). Start the ml-service in the same mode from conda:
#   cd apps/ml-service && INFERENCE_MODE=real \
#     MODEL_V2_PATH=C:/Users/akaro/Documents/GitHub/federated-learning-model \
#     FEDSCRT_CKPT=C:/Users/akaro/Documents/GitHub/federated-learning-model/checkpoints/fedscrt_final.pt \
#     MRI_NUM_CLASSES=2 conda run -n mri_thesis python -m uvicorn main:app --port 8001
INFERENCE_MODE="mock"
ML_SERVICE_URL="http://localhost:8001"

# ── FL Coordinator ────────────────────────────────────────────────────────
FL_MODE="mock"
FL_COORDINATOR_URL="http://localhost:8002"

# ── Attention Maps ────────────────────────────────────────────────────────
ATTN_MODE="blob"

# ── Active Learning ───────────────────────────────────────────────────────
AL_MODE="mock"

# ── Backend webhook secret ────────────────────────────────────────────────
FL_WEBHOOK_SECRET="dev-webhook-secret"

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_APP_NAME="FedMRI"
