# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fedmri:fedmri@localhost:5432/fedmri"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-in-prod"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-prod"
JWT_ACCESS_EXPIRES="8h"
JWT_REFRESH_EXPIRES="7d"

# ── AI / Chat ─────────────────────────────────────────────────────────────
# LLM provider: ollama (local, free) | deepseek (cheap API) | anthropic
# ── AI / Chat (Ollama, local lightweight model) ───────────────────────────
# The in-app assistant uses Ollama with llama3.2:3b (~2 GB, runs locally, low
# resources). Models live on D: via the docker-compose ollama volume
# (D:/ollama-models). Pull once: docker exec fedmri-ollama ollama pull llama3.2:3b
LLM_PROVIDER="ollama"
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
# Ollama (default — local, runs in Docker, models stored on D:/ollama-models)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"

# DeepSeek (cheap API alternative — get key from platform.deepseek.com)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"

# Anthropic (kept for fallback compatibility, no longer the default)
ANTHROPIC_API_KEY=""

# ── Storage ───────────────────────────────────────────────────────────────
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"

# ── ML Inference ──────────────────────────────────────────────────────────
# real = ml-service runs the FedSCRT ConvNeXt-MIL checkpoint from the in-repo
# model-core/ (default — no MODEL_V2_PATH/FEDSCRT_CKPT needed). From conda:
  cd apps/ml-service && INFERENCE_MODE=real \
#     conda run -n mri_thesis python -m uvicorn main:app --port 8001

# ── FL Coordinator ────────────────────────────────────────────────────────
FL_MODE="mock"
FL_COORDINATOR_URL="http://localhost:8002"

# ── Attention Maps ────────────────────────────────────────────────────────
ATTN_MODE="blob"

# ── Active Learning ───────────────────────────────────────────────────────
AL_MODE="mock"

# ── Backend webhook secret ────────────────────────────────────────────────
FL_WEBHOOK_SECRET="dev-webhook-secret"

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_APP_NAME="FedMRI"
