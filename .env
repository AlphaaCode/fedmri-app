# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fedmri:fedmri@localhost:5432/fedmri"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-in-prod"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-prod"
JWT_ACCESS_EXPIRES="8h"
JWT_REFRESH_EXPIRES="7d"

# ── AI / Chat ─────────────────────────────────────────────────────────────
# LLM provider: ollama (local, free) | deepseek (cheap API) | anthropic
LLM_PROVIDER="ollama"

# Ollama (default — local, runs in Docker, models stored on D:/ollama-models)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"

# DeepSeek (cheap API alternative — get key from platform.deepseek.com)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"

# Anthropic (kept for fallback compatibility, no longer the default)
ANTHROPIC_API_KEY=""

# ── Storage ───────────────────────────────────────────────────────────────
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"

# ── ML Inference ──────────────────────────────────────────────────────────
INFERENCE_MODE="mock"
ML_SERVICE_URL="http://localhost:8001"

# ── FL Coordinator ────────────────────────────────────────────────────────
FL_MODE="mock"
FL_COORDINATOR_URL="http://localhost:8002"

# ── Attention Maps ────────────────────────────────────────────────────────
ATTN_MODE="blob"

# ── Active Learning ───────────────────────────────────────────────────────
AL_MODE="mock"

# ── Backend webhook secret ────────────────────────────────────────────────
FL_WEBHOOK_SECRET="dev-webhook-secret"

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_APP_NAME="FedMRI"
