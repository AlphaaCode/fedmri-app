# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fedmri:fedmri@localhost:5432/fedmri"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-in-prod"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-prod"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── AI / Chat ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Storage ───────────────────────────────────────────────────────────────
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"

# ── ML Inference ──────────────────────────────────────────────────────────
INFERENCE_MODE="mock"
ML_SERVICE_URL="http://localhost:8001"

# ── FL Coordinator ────────────────────────────────────────────────────────
FL_MODE="mock"
FL_COORDINATOR_URL="http://localhost:8002"

# ── Attention Maps ────────────────────────────────────────────────────────
ATTN_MODE="blob"

# ── Active Learning ───────────────────────────────────────────────────────
AL_MODE="mock"

# ── Backend webhook secret ────────────────────────────────────────────────
FL_WEBHOOK_SECRET="dev-webhook-secret"

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_APP_NAME="FedMRI"
