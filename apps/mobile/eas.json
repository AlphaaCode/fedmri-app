{
  "cli": {
    "version": ">= 19.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk", "image": "latest" },
      "node": "20.19.4"
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk", "image": "latest" },
      "node": "20.19.4",
      "env": {
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "app-bundle", "image": "latest" },
      "node": "20.19.4"
    }
  },
  "submit": {
    "production": {}
  }
}
