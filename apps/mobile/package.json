    "@types/react": "~19.2.10",
    "typescript": "~6.0.3"
  },
  "expo": {
    "install": {
      "//": "react/react-dom MUST be exactly 19.2.3 to match react-native 0.85.3's bundled react-native-renderer (19.2.3) — a mismatch crashes at launch with 'Incompatible React versions'. The web app uses 19.2.4 at the monorepo root; metro.config forces mobile to resolve its OWN local 19.2.3, so the duplicate-react doctor warning is expected and correct to ignore.",
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "private": true
