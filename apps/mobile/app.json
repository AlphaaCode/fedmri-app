{
  "expo": {
    "name": "FedMRI",
    "slug": "fedmri-mobile",
    "version": "1.0.0",
    "scheme": "fedmri",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "local.fedmri.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "FedMRI uses the camera to capture MRI scan images.",
        "NSPhotoLibraryUsageDescription": "FedMRI accesses photos to upload MRI scan images.",
        "NSAppTransportSecurity": { "NSAllowsArbitraryLoads": true }
      }
    },
    "android": {
      "package": "local.fedmri.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FedMRI to access your camera to capture MRI scan images."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FedMRI to access your photos to upload MRI scan images."
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://10.0.2.2:3001",
      "eas": {
        "projectId": "460eec42-89ad-4624-b5b2-4d8da0d0be85"
      }
    }
  }
}
