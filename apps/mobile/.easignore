# Exclude monorepo non-mobile packages from EAS upload
node_modules
../../node_modules

# Native dirs are generated by prebuild on EAS from app.json + config plugins.
# Without these entries, .easignore (which overrides .gitignore for EAS) would
# upload the stale local android/ios and EAS would skip prebuild — dropping
# config-plugin output like usesCleartextTraffic, splash, and autolinking.
/android
/ios
../../apps/web
../../apps/backend
../../apps/ml-service
../../apps/fl-coordinator
../../packages
../../docs
../../tasks
../../graphify-out
../../.scratch
../../3D
*.log
__pycache__
.turbo
