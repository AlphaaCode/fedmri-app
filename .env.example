# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fedmri:fedmri@localhost:5432/fedmri"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-in-prod-access"
JWT_REFRESH_SECRET="change-me-in-prod-refresh"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── AI / Chat ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Storage ───────────────────────────────────────────────────────────────
# local | minio | s3
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"
MINIO_ENDPOINT=""
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET="fedmri"

# ── ML Inference ──────────────────────────────────────────────────────────
# mock | real
INFERENCE_MODE="mock"
ML_SERVICE_URL="http://localhost:8001"
MODEL_CHECKPOINT_PATH="./checkpoints/best_model.pt"

# ── FL Coordinator ────────────────────────────────────────────────────────
# mock | flower
FL_MODE="mock"
FL_COORDINATOR_URL="http://localhost:8002"
FLOWER_SERVER_HOST="0.0.0.0"
FLOWER_SERVER_PORT="9080"
# Comma-separated IPs of hospital Flower clients (prod only)
FLOWER_CLIENT_ADDRESSES=""

# ── Attention Maps ────────────────────────────────────────────────────────
# blob | mil
ATTN_MODE="blob"

# ── Active Learning ───────────────────────────────────────────────────────
# mock | real
AL_MODE="mock"

# ── Backend webhook secret ────────────────────────────────────────────────
FL_WEBHOOK_SECRET="change-me-webhook-secret"

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_APP_NAME="FedMRI"
