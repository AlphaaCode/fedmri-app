node_modules
.gstack/

# Stray 3D asset dump (not part of the app)
3D/

# brainstorming visual companion artifacts
.superpowers/

# Python virtualenv — must NOT be committed. It is currently still tracked; untrack
# once with:  git rm -r --cached apps/ml-service/.venv_ml
apps/ml-service/.venv_ml/
__pycache__/
*.pyc

# Active-learning runtime state (the learned confidence bias, persisted at runtime —
# not source; mounted into the ml-service container at /al-state)
apps/ml-service/.al-state/al_state.json

# Runtime scan uploads written by the backend (mounted into ml-service for attention)
apps/backend/uploads-tmp/*
!apps/backend/uploads-tmp/.gitkeep

# Model checkpoints — large binaries (58 MB), mounted at runtime, never in git
*.pt
model_core/
