{
  "name": "fedmri",
  "version": "1.0.0",
  "private": true,
  "description": "Federated learning for breast cancer MRI",
  "packageManager": "npm@10.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run start:dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:push": "cd apps/backend && npx prisma db push",
    "db:seed": "cd apps/backend && npx prisma db seed",
    "db:studio": "cd apps/backend && npx prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
